# Copy this file to ".env" and fill in the values from your Supabase project.
# Supabase dashboard -> Project Settings -> Data API / API Keys
#
# These two are SAFE to expose in a frontend build (the anon key is public by
# design and is protected by Row Level Security). Never put the service_role
# key here.

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
